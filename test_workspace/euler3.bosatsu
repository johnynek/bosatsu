package Euler/Three

# see:
# https://projecteuler.net/problem=3
# What is the largest prime factor of the number 600851475143 ?

#number = 13195
number = 600851475143

operator - = sub
operator + = add
operator == = eq_Int

def divides(a, b): b.mod_Int(a) == 0

def smallest_factor(n):
  match n:
    case 1: 1
    case _:
      def loop_smallest(rem, trial):
        loop rem:
          case _ if trial.divides(n):
            trial
          case _ if cmp_Int(rem, 1) matches GT:
            loop_smallest(rem - 1, trial + 1)
          case _:
            -1
      loop_smallest(n, 2)

def all_factors(n):
  def loop_factors(fuel, current, facs):
    loop fuel:
      case _ if cmp_Int(fuel, 0) matches GT:
        next_factor = smallest_factor(current)
        next_facs = [next_factor, *facs]
        match current.div(next_factor):
          case 1: next_facs
          case smaller: loop_factors(fuel.sub(1), smaller, next_facs)
      case _:
        facs
  loop_factors(n, n, [])

def largest_factor(n):
  match all_factors(n):
    case []: n
    case [h, *_]: h

test = Assertion(largest_factor(number) == 6857, "trial")
