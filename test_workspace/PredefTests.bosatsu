package PredefTests

from Bosatsu/Num/Float64 import (
  float64_bits_to_Int,
  float64_to_Int,
  float64_to_String,
  int_bits_to_Float64,
  int_to_Float64,
  is_infinite,
  is_nan,
  string_to_Float64,
)
from Bosatsu/Loops import range_foldr

operator / = div
operator % = mod_Int

i = int_to_String

def oi(opt):
  match opt:
    case None: "None"
    case Some(v): "Some(${i(v)})"

def notb(a):
  match a:
    case True: False
    case False: True
def andb(a, b):
  match a:
    case True: b
    case False: False

