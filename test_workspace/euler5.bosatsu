package Euler/P5

from Bosatsu/List import for_all

# 2520 is the smallest number that can be divided by each of the numbers from 1 to 10 without any remainder.
#
# What is the smallest positive number that is evenly divisible by all of the numbers from 1 to 20?

operator + = add

def factorial(n):
  def loop_factorial(i, p):
    loop i:
      case _ if cmp_Int(i, 0) matches GT:
        loop_factorial(i.sub(1), p.mul(i))
      case _:
        p

  loop_factorial(n, 1)

max_candidate = factorial(10)

# just start at 1 and take the first number that
# is divisible by all

bound = max_candidate.add(1)

def divides(denom, num):
  num.mod_Int(denom).eq_Int(0)

factors = range(10)

def keep(n): for_all(factors, f -> (f + 1).divides(n))

def find_div_all(rem):
  loop rem:
    case _ if cmp_Int(rem, 0) matches GT:
      cand = bound.sub(rem).add(1)
      if keep(cand): cand
      else: find_div_all(rem.sub(1))
    case _:
      0

div_all = find_div_all(bound)

test = Assertion(div_all.eq_Int(2520), "test")
