package Bosatsu/Testing/Properties

from Bosatsu/Rand import (Rand, run_Rand, prod_Rand, map_Rand,
  int_range, sequence_Rand)

export (Prop, forall_Prop, suite_Prop, run_Prop)
exposes Bosatsu/Rand

struct Prop(fn: Int -> Rand[Test])

def operator +(a, b): a.add(b)
def operator -(a, b): a.sub(b)
def operator &(a, b): a.and_Int(b)
def operator <<(a, b): a.shift_left_Int(b)
def operator >>(a, b): a.shift_right_Int(b)
def operator |(a, b): a.or_Int(b)
def operator ^(a, b): a.xor_Int(b)


def forall_Prop[a](rand: Rand[a], name: String, fn: a -> Test) -> Prop:
  Prop(cnt -> (
    rands = replicate_List(rand, cnt)
    seq = sequence_Rand(rands)
    seq.map_Rand(as -> TestSuite(name, as.map_List(fn)))
  ))

def suite_Prop(name: String, props: List[Prop]) -> Prop:
  Prop(seed ->
    suites_rand = sequence_Rand(props.map_List(Prop(fn) -> fn(seed)))
    suites_rand.map_Rand(as -> TestSuite(name, as))
  )

def run_Prop(prop: Prop, trials: Int, seed: Int) -> Test:
  Prop(fn) = prop
  rand = fn(trials)
  run_Rand(rand, seed)

signed64 = int_range(1 << 64).map_Rand(i -> i - (1 << 63))

word32_bound = 1 << 32
word32_rand = int_range(word32_bound)
nonzero_word32_rand = int_range(word32_bound - 1).map_Rand(i -> i + 1)

def from_words(words, acc):
  loop words:
    case []: acc
    case [h, *t]: from_words(t, (acc << 32) + h)

wide_positive_15 = prod_Rand(
  nonzero_word32_rand,
  sequence_Rand(replicate_List(word32_rand, 14))
).map_Rand(((top, tail)) -> from_words(tail, top))

wide_positive_16 = prod_Rand(
  nonzero_word32_rand,
  sequence_Rand(replicate_List(word32_rand, 15))
).map_Rand(((top, tail)) -> from_words(tail, top))

def operator ==(a, b): eq_Int(a, b)

not_law = forall_Prop(
  signed64,
  "not_law",
  i -> (
    istr = int_to_String(i)
    Assertion(i.not_Int() == (-1 - i), "~${istr} == (-1 - ${istr})")
  ))

shift_unshift_law = forall_Prop(
  signed64.prod_Rand(int_range(32)),
  "shift_unshift_law",
  ((i, k)) -> (
    istr = int_to_String(i)
    kstr = int_to_String(k)
    result = (i << k) >> k
    Assertion(result == i, "(${istr} << ${kstr}) >> ${kstr} == ${istr}, got: ${int_to_String(result)}")
  ))

def gtez(x): x.cmp_Int(0) matches (GT | EQ)
operator || = or
def implies(a, b): b if a else True

positive_and_law = forall_Prop(
  signed64.prod_Rand(signed64),
  "x & y is >= 0 implies x >= 0 or y >= 0",
  ((x, y)) -> (
    xs = int_to_String(x)
    ys = int_to_String(y)
    msg = "${xs} & ${ys} is >= 0 implies ${xs} >= 0 or ${ys} >= 0"
    res = gtez(x & y).implies(gtez(x) || gtez(y))
    Assertion(res, msg)
  ))

wide_positive_mismatched_bitwise_law = forall_Prop(
  wide_positive_16.prod_Rand(wide_positive_15),
  "wide positive mismatched-width bitwise laws",
  ((longer, shorter)) -> (
    or_lr = longer | shorter
    or_rl = shorter | longer
    xor_lr = longer ^ shorter
    xor_rl = shorter ^ longer
    TestSuite("wide positive mismatched-width bitwise laws", [
      Assertion((or_lr & shorter) == shorter, "or keeps all shorter bits"),
      Assertion((or_lr & longer) == longer, "or keeps all longer bits"),
      Assertion(or_lr == or_rl, "or is commutative for mismatched widths"),
      Assertion((xor_lr & shorter) == (shorter & longer.not_Int()), "xor matches shorter masked complement"),
      Assertion((xor_lr & longer) == (longer & shorter.not_Int()), "xor matches longer masked complement"),
      Assertion(xor_lr == xor_rl, "xor is commutative for mismatched widths"),
    ])
  ))

all_props = suite_Prop(
  "integer props", [
    not_law,
    shift_unshift_law,
    positive_and_law,
    wide_positive_mismatched_bitwise_law,
  ])
  
test = run_Prop(all_props, 100, 42)
