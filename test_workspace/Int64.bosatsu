package Bosatsu/Num/Int64

from Bosatsu/Predef import Float64

export (
  Int64,
  min_i64,
  max_i64,
  int_to_Int64,
  int_low_bits_to_Int64,
  int64_to_Int,
  int64_to_Float64,
  float64_to_Int64,
  add_Int64,
  sub_Int64,
  mul_Int64,
  div_Int64,
  and_Int64,
  or_Int64,
  xor_Int64,
  not_Int64,
  shift_left_Int64,
  shift_right_Int64,
  cmp_Int64,
  eq_Int64,
  operator +,
  operator -,
  operator *,
  operator /,
  operator &,
  operator |,
  operator ^,
  operator <<,
  operator >>,
)

external struct Int64

external min_i64: Int64
external max_i64: Int64

external def int_to_Int64(i: Int) -> Option[Int64]
external def int_low_bits_to_Int64(i: Int) -> Int64
external def int64_to_Int(i: Int64) -> Int
external def int64_to_Float64(i: Int64) -> Float64
external def float64_to_Int64(f: Float64) -> Option[Int64]
external def add_Int64(a: Int64, b: Int64) -> Int64
external def sub_Int64(a: Int64, b: Int64) -> Int64
external def mul_Int64(a: Int64, b: Int64) -> Int64
external def div_Int64(a: Int64, b: Int64) -> Int64
external def and_Int64(a: Int64, b: Int64) -> Int64
external def or_Int64(a: Int64, b: Int64) -> Int64
external def xor_Int64(a: Int64, b: Int64) -> Int64
external def not_Int64(a: Int64) -> Int64
external def shift_left_Int64(a: Int64, n: Int) -> Int64
external def shift_right_Int64(a: Int64, n: Int) -> Int64
external def cmp_Int64(a: Int64, b: Int64) -> Comparison

def eq_Int64(a: Int64, b: Int64) -> Bool:
  cmp_Int64(a, b) matches EQ

def operator +(a, b): add_Int64(a, b)
def operator -(a, b): sub_Int64(a, b)
def operator *(a, b): mul_Int64(a, b)
def operator /(a, b): div_Int64(a, b)
def operator &(a, b): and_Int64(a, b)
def operator |(a, b): or_Int64(a, b)
def operator ^(a, b): xor_Int64(a, b)
def operator <<(a, b): shift_left_Int64(a, b)
def operator >>(a, b): shift_right_Int64(a, b)
