package Euler/P7

from Bosatsu/List import for_all

# By listing the first six prime numbers: 2, 3, 5, 7, 11, and 13, we can see that the 6th prime is 13.
# What is the 10 001st prime number?

operator == = eq_Int

def divides(denom, num):
  num.mod_Int(denom).eq_Int(0)

def is_prime(x):
  def loop_prime(rem, candidate):
    loop rem:
      case _ if cmp_Int(rem, 0) matches GT:
        match cmp_Int(candidate, x):
          case LT:
            if candidate.divides(x): False
            else: loop_prime(rem.sub(1), candidate.add(1))
          case _:
            True
      case _:
        True

  loop_prime(x, 2)

def none_divide(primes, x):
  for_all(primes, p -> not(p.divides(x)))

# the gap between primes might be as small as (log N)^2, so
# even if the gap is O(N), clearly false, we would only have
# to sum up to k^2 values to find the k^th prime.
# we need to know a finite upper bound since we can't loop forever.
def ith_prime(total):
  max_size = total.mul(total)
  def loop_primes(rem, candidate, primes, cnt):
    loop rem:
      case _ if cmp_Int(rem, 0) matches GT:
        match cmp_Int(cnt, total):
          case LT:
            if none_divide(primes, candidate):
              loop_primes(rem.sub(1), candidate.add(1), [candidate, *primes], cnt.add(1))
            else:
              loop_primes(rem.sub(1), candidate.add(1), primes, cnt)
          case _:
            primes
      case _:
        primes

  ps = loop_primes(max_size, 2, [], 0)

  match ps:
    case [h, *_]: h
    case []: -1

test =
    TestSuite("euler 7", [
        Assertion(is_prime(13), "6th prime is 13"),
        Assertion(ith_prime(6) == 13, "6th prime is 13"),
        Assertion(ith_prime(11) == 31, "11th prime is 31"),
    ])
