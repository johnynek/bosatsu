package Bosatsu/Eval

from Bosatsu/Lazy import Lazy, lazy, get_Lazy

export (
  Eval, done, from_Lazy, lazy_Eval, always, map, flat_map, eval, unit_Eval,
  defer, true_Eval, false_Eval, zero_Eval, one_Eval
)
# port of cats.Eval to bosatsu

enum Leaf[a: +*]:
    Done(done: a), LazyLeaf(run_lazy: Lazy[a]), Always(run: () -> a)

def eval_Leaf(leaf: Leaf[a]) -> a:
    match leaf:
        case Done(a): a
        case LazyLeaf(l): get_Lazy(l)
        case Always(fn): fn()

enum Eval[a: +*]:
    Pure(value: Leaf[a])
    FlatMap[b](prev: Eval[b], fn: b -> Eval[a])

def done(a: a) -> Eval[a]: Pure(Done(a))
# this lifts a Lazy into an Eval
def from_Lazy(lzy: Lazy[a]) -> Eval[a]: Pure(LazyLeaf(lzy))
# this makes an Eval that evaluates the thunk one time
def lazy_Eval(fn: () -> a) -> Eval[a]: from_Lazy(lazy(fn))
# this calls the thunk every time it is needed
def always(fn: () -> a) -> Eval[a]: Pure(Always(fn))

def flat_map[a, b](e: Eval[a], fn: a -> Eval[b]) -> Eval[b]:
    FlatMap(e, fn)

def map[a, b](e: Eval[a], fn: a -> b) -> Eval[b]:
    x <- e.flat_map()
    done(fn(x))

unit_Eval: Eval[Unit] = done(())
true_Eval: Eval[Bool] = done(True)
false_Eval: Eval[Bool] = done(False)
zero_Eval: Eval[Int] = done(0)
one_Eval: Eval[Int] = done(1)

def defer(fn: () -> Eval[a]) -> Eval[a]:
    unit_Eval.flat_map(fn)   

enum Stack[a, b]:
    Last(fn: a -> Eval[b])
    More[c](first: a -> Eval[c], rest: Stack[c, b])

enum Loop[b]:
    RunStack[a](a: a, stack: Stack[a, b])
    RunEval[a](e: Eval[a], stack: Stack[a, b])

# Termination proof for this external loop is in:
# lean_proofs/LeanProofs/EvalFuelExistence.lean
external def eval_loop[a](loop: Loop[a]) -> a

# Previous fuel-based implementation kept for reference:
# def eval_loop[a](budget: Int, arg: Loop[a]) -> Option[a]:
#     recur (budget, arg):
#         case _ if cmp_Int(budget, 0) matches LT | EQ: None
#         case (_, RunEval(Pure(a), stack)):
#             eval_loop(budget.sub(1), RunStack(eval_Leaf(a), stack))
#         case (_, RunEval(FlatMap(prev, fn), stack)):
#             eval_loop(budget.sub(1), RunEval(prev, More(fn, stack)))
#         case (_, RunStack(a, More(first, rest))):
#             eval_loop(budget.sub(1), RunEval(first(a), rest))

def eval(e: Eval[a]) -> a:
    match e:
        case Pure(l): eval_Leaf(l)
        case FlatMap(prev, fn):
            eval_loop(RunEval(prev, Last(fn)))

def sum_defer(n: Int) -> Eval[Int]:
    recur n:
        case _ if cmp_Int(n, 0) matches LT | EQ:
            zero_Eval
        case _:
            prev <- defer(() -> sum_defer(n.sub(1))).flat_map()
            done(prev.add(n))

small_sum = eval(sum_defer(10))
long_n = 5000
long_sum = eval(sum_defer(long_n))
long_expected = long_n.mul(long_n.add(1)).div(2)

tests = TestSuite("Eval tests", [
    Assertion(eval(done(11)) matches 11, "eval done"),
    Assertion(eval(always(() -> 19)) matches 19, "eval always"),
    Assertion(eval(done(40).flat_map(x -> done(x.add(2)))) matches 42, "flat_map composition"),
    Assertion(eq_Int(small_sum, 55), "small defer sum"),
    Assertion(eq_Int(long_sum, long_expected), "long defer sum"),
])
