package Bosatsu/Collection/Array

from Bosatsu/Num/Float64 import (
  addf,
  eq_Float64,
  float64_bits_to_Int,
  int_to_Float64,
  mulf,
)
from Bosatsu/Num/Int64 import (
  Int64,
  cmp_Int64,
  eq_Int64,
  int64_to_Int,
  int_low_bits_to_Int64 as i64,
  int_to_Int64,
)
from Bosatsu/Option import eq_Option
from Bosatsu/List import eq_List, zip
from Bosatsu/Testing/Properties import forall_Prop, run_Prop
from Bosatsu/Rand import (Rand, flat_map_Rand, int_range, map_Rand, prod_Rand)
from Bosatsu/Char import (
  char_to_Int,
  string_to_Char_List,
  int_List_to_Char_List,
  int_List_to_String,
)

export (
  Array,
  empty_Array,
  tabulate_Array,
  from_List_Array,
  to_List_Array,
  size_Array,
  get_Array,
  get_or_Array,
  foldl_Array,
  foldl_with_index_Array,
  foldr_Array,
  map_Array,
  map_with_index_Array,
  filter_Array,
  flat_map_Array,
  zip_map_Array,
  zip_foldl_Array,
  zip_sumf_Array,
  sumf_Array,
  sumsqf_Array,
  dotf_Array,
  set_or_self_Array,
  sort_Array,
  concat_all_Array,
  slice_Array,
  char_Array_to_String,
  string_to_Char_Array,
  char_Array_to_Int_Array,
  string_to_Int_Array,
  int_Array_to_Char_Array,
  int_Array_to_String,
  index_in_range_Array,
  get_map_Array,
  set_Array,
  range_Array,
  range_from_Array,
  reverse_Array,
  flatten_Array
)
exposes Bosatsu/Num/Int64

external struct Array[a: +*]

external empty_Array: forall a. Array[a]

external def tabulate_Array[a](n: Int64, fn: Int64 -> a) -> Array[a]
external def from_List_Array[a](xs: List[a]) -> Array[a]
external def to_List_Array[a](ary: Array[a]) -> List[a]
external def size_Array[a](ary: Array[a]) -> Int64
external def get_map_Array[a, b](ary: Array[a], idx: Int64, default: Int64 -> b, fn: a -> b) -> b
external def get_or_Array[a](ary: Array[a], idx: Int64, default: Int64 -> a) -> a
external def foldl_Array[a, b](ary: Array[a], init: b, fn: (b, a) -> b) -> b
external def foldl_with_index_Array[a, b](ary: Array[a], init: b, fn: (b, a, Int64) -> b) -> b
external def foldr_Array[a, b](ary: Array[a], init: b, fn: (a, b) -> b) -> b
external def map_Array[a, b](ary: Array[a], fn: a -> b) -> Array[b]
external def map_with_index_Array[a, b](ary: Array[a], fn: (a, Int64) -> b) -> Array[b]
external def filter_Array[a](ary: Array[a], fn: a -> Bool) -> Array[a]
external def flat_map_Array[a, b](ary: Array[a], fn: a -> Array[b]) -> Array[b]
external def zip_map_Array[a, b, c](left: Array[a], right: Array[b], fn: (a, b) -> c) -> Array[c]
external def zip_foldl_Array[a, b, c](left: Array[a], right: Array[b], init: c, fn: (c, a, b) -> c) -> c
external def zip_sumf_Array[a, b](left: Array[a], right: Array[b], fn: (a, b) -> Float64) -> Float64
external def sumf_Array(ary: Array[Float64]) -> Float64
external def sumsqf_Array(ary: Array[Float64]) -> Float64
external def dotf_Array(left: Array[Float64], right: Array[Float64]) -> Float64
external def set_or_self_Array[a](ary: Array[a], idx: Int64, value: a) -> Array[a]
external def sort_Array[a](ary: Array[a], fn: (a, a) -> Comparison) -> Array[a]
external def concat_all_Array[a](arrays: List[Array[a]]) -> Array[a]
external def slice_Array[a](ary: Array[a], start: Int64, end: Int64) -> Array[a]
external def char_Array_to_String(chars: Array[Char]) -> String

def string_to_Char_Array(s: String) -> Array[Char]:
  from_List_Array(string_to_Char_List(s))

def char_Array_to_Int_Array(chars: Array[Char]) -> Array[Int]:
  map_Array(chars, char_to_Int)

def string_to_Int_Array(s: String) -> Array[Int]:
  char_Array_to_Int_Array(string_to_Char_Array(s))

def int_Array_to_Char_Array(code_points: Array[Int]) -> Option[Array[Char]]:
  match int_List_to_Char_List(to_List_Array(code_points)):
    case Some(chars): Some(from_List_Array(chars))
    case None: None

def int_Array_to_String(code_points: Array[Int]) -> Option[String]:
  int_List_to_String(to_List_Array(code_points))

def get_Array[a](ary: Array[a], idx: Int64) -> Option[a]:
  get_map_Array(ary, idx, _ -> None, x -> Some(x))

def index_in_range_Array[a](ary: Array[a], idx: Int64) -> Bool:
  if cmp_Int64(idx, i64(0)) matches LT:
    False
  else:
    cmp_Int64(idx, size_Array(ary)) matches LT

def set_Array[a](ary: Array[a], idx: Int64, value: a) -> Option[Array[a]]:
  if index_in_range_Array(ary, idx):
    Some(set_or_self_Array(ary, idx, value))
  else:
    None

def range_Array(n: Int) -> Array[Int]:
  match int_to_Int64(n):
    case Some(n64): tabulate_Array(n64, int64_to_Int)
    case None: empty_Array

def range_from_Array(start: Int, n: Int64) -> Array[Int]:
  tabulate_Array(n, i -> add(start, int64_to_Int(i)))

def reverse_Array[a](ary: Array[a]) -> Array[a]:
  rev_list = foldl_Array(ary, [], (acc, x) -> [x, *acc])
  from_List_Array(rev_list)

def flatten_Array[a](arrays: Array[Array[a]]) -> Array[a]:
  flat_map_Array(arrays, arr -> arr)

########
## test code below
########

def eq_Array(eq_a: (a, a) -> Bool)(left: Array[a], right: Array[a]) -> Bool:
  if cmp_Int64(size_Array(left), size_Array(right)) matches EQ:
    foldl_with_index_Array(
      left,
      True,
      (acc, item, idx) ->
        if acc:
          get_map_Array(right, idx, _ -> False, right_item -> eq_a(item, right_item))
        else:
          False
    )
  else:
    False

def int_range_list(start: Int, len: Int) -> List[Int]:
  [add(start, offset) for offset in range(len)]

def foldl_with_index_List[a, b](items: List[a], init: b, fn: (b, a, Int) -> b) -> b:
  (acc, _) =
    items.foldl_List((init, 0), ((acc, idx), item) -> (fn(acc, item, idx), idx.add(1)))
  acc

def zip_map_List[a, b, c](left: List[a], right: List[b], fn: (a, b) -> c) -> List[c]:
  [fn(l, r) for (l, r) in zip(left, right)]

def zip_foldl_List[a, b, c](left: List[a], right: List[b], init: c, fn: (c, a, b) -> c) -> c:
  zip(left, right).foldl_List(init, (acc, (l, r)) -> fn(acc, l, r))

def sumf_List(items: List[Int]) -> Float64:
  items.foldl_List(0.0, (acc, item) -> addf(acc, int_to_Float64(item)))

def sumsqf_List(items: List[Int]) -> Float64:
  items.foldl_List(0.0, (acc, item) ->
    addf(acc, mulf(int_to_Float64(item), int_to_Float64(item))))

def dotf_List(left: List[Int], right: List[Int]) -> Float64:
  ([mulf(int_to_Float64(l), int_to_Float64(r)) for (l, r) in zip(left, right)]).foldl_List(0.0, addf)

def cmp_pair(left: (Int, String), right: (Int, String)) -> Comparison:
  (li, _) = left
  (ri, _) = right
  cmp_Int(li, ri)

eq_ai = eq_Array(eq_Int)
eq_oi = eq_Option(eq_Int)

a0 = empty_Array

a5 = range_Array(5)
a0_copy = from_List_Array([])
a1 = from_List_Array([7])
a1_copy = from_List_Array([7])
a1_diff = from_List_Array([9])
a5_copy = from_List_Array([0, 1, 2, 3, 4])
a5_first_diff = from_List_Array([99, 1, 2, 3, 4])
a5_last_diff = from_List_Array([0, 1, 2, 3, 99])
a5_tail = slice_Array(a5, i64(2), i64(5))
a_from = range_from_Array(10, i64(4))
a_set = set_or_self_Array(a5, i64(2), 99)
a_sorted = sort_Array(
  from_List_Array([(1, "a"), (0, "z"), (1, "b"), (1, "c")]),
  cmp_pair
)

def set_in_range_ok() -> Bool:
  match set_Array(a5, i64(1), 8):
    case Some(arr): to_List_Array(arr) matches [0, 8, 2, 3, 4]
    case None: False

def int_to_char_array_some() -> Bool:
  match int_Array_to_Char_Array(from_List_Array([65, 128075])):
    case Some(chars): to_List_Array(chars) matches [.'A', .'👋']
    case None: False

rand_Int: Rand[Int] = map_Rand(int_range(200), i -> i.sub(100))
rand_Array_and_Init: Rand[(Array[Int], Int)] = map_Rand(
  prod_Rand(prod_Rand(rand_Int, int_range(40)), rand_Int),
  (((start, len), init)) -> (range_from_Array(start, i64(len)), init)
)
rand_StartAndLen: Rand[(Int, Int)] =
  map_Rand(prod_Rand(rand_Int, int_range(30)), ((start, len)) -> (start, len))
rand_SliceCase: Rand[(Int, Int, Int, Int)] =
  flat_map_Rand(
    prod_Rand(rand_Int, int_range(25)),
    ((start, base_len)) ->
      flat_map_Rand(
        int_range(base_len.add(1)),
        slice_start ->
          map_Rand(
            int_range(base_len.sub(slice_start).add(1)),
            visible_len -> (start, base_len, slice_start, visible_len)
          )
      )
  )
rand_ZipCase: Rand[(Int, Int, Int, Int)] =
  map_Rand(
    prod_Rand(prod_Rand(rand_Int, int_range(20)), prod_Rand(rand_Int, int_range(20))),
    (((left_start, left_len), (right_start, right_len))) ->
      (left_start, left_len, right_start, right_len)
  )

foldr_reverse_law = forall_Prop(
  rand_Array_and_Init,
  "reverse + foldl == foldr",
  ((arr, init)) -> (
    foldr_res = foldr_Array(arr, init, (item, acc) -> add(mul(item, 31), acc))
    foldl_res = foldl_Array(reverse_Array(arr), init, (acc, item) -> add(mul(item, 31), acc))
    Assertion(eq_Int(foldr_res, foldl_res), "foldr follows reverse + foldl")
  ))

tabulate_law = forall_Prop(
  rand_StartAndLen,
  "tabulate_Array size and order follow the Int64 model",
  ((start, len)) -> (
    n64 = i64(len)
    arr = tabulate_Array(n64, idx -> add(start, int64_to_Int(idx)))
    expected = int_range_list(start, len)
    size_ok = eq_Int64(size_Array(arr), n64)
    list_ok = eq_List(eq_Int)(to_List_Array(arr), expected)
    Assertion(and(size_ok, list_ok), "tabulate uses visible Int64 indices in ascending order")
  ))

indexed_slice_law = forall_Prop(
  rand_SliceCase,
  "indexed Array functions use slice-relative visible indices",
  ((start, base_len, slice_start, visible_len)) -> (
    base = range_from_Array(start, i64(base_len))
    view = slice_Array(base, i64(slice_start), i64(slice_start.add(visible_len)))
    expected = int_range_list(start.add(slice_start), visible_len)
    mapped = to_List_Array(map_with_index_Array(view, (_, idx) -> int64_to_Int(idx)))
    mapped_expected = int_range_list(0, visible_len)
    folded = foldl_with_index_Array(
      view,
      0,
      (acc, item, idx) -> add(acc, add(item, int64_to_Int(idx)))
    )
    folded_expected = foldl_with_index_List(
      expected,
      0,
      (acc, item, idx) -> add(acc, add(item, idx))
    )
    head_ok =
      if cmp_Int(visible_len, 0) matches GT:
        eq_Int(get_or_Array(view, i64(0), int64_to_Int), add(start, slice_start))
      else:
        eq_Int(get_or_Array(view, i64(0), int64_to_Int), 0)
    miss_idx = visible_len.add(1)
    miss_ok = eq_Int(get_or_Array(view, i64(miss_idx), int64_to_Int), miss_idx)
    ok = and(
      head_ok,
      and(
        miss_ok,
        and(
          eq_List(eq_Int)(mapped, mapped_expected),
          eq_Int(folded, folded_expected)
        )
      )
    )
    Assertion(ok, "get_or/map_with_index/foldl_with_index stay relative to the visible slice")
  ))

zip_and_float_law = forall_Prop(
  rand_ZipCase,
  "zip helpers and Float64 reductions follow list-prefix models",
  ((left_start, left_len, right_start, right_len)) -> (
    left = range_from_Array(left_start, i64(left_len))
    right = range_from_Array(right_start, i64(right_len))
    left_list = int_range_list(left_start, left_len)
    right_list = int_range_list(right_start, right_len)
    zipped = to_List_Array(zip_map_Array(left, right, (l, r) -> sub(l, r)))
    zipped_expected = zip_map_List(left_list, right_list, sub)
    folded = zip_foldl_Array(left, right, 0, (acc, l, r) -> add(acc, sub(l, r)))
    folded_expected = zip_foldl_List(left_list, right_list, 0, (acc, l, r) -> add(acc, sub(l, r)))
    leftf = map_Array(left, int_to_Float64)
    rightf = map_Array(right, int_to_Float64)
    sum_ok = eq_Float64(sumf_Array(leftf), sumf_List(left_list))
    sumsq_ok = eq_Float64(sumsqf_Array(leftf), sumsqf_List(left_list))
    dot_ok = eq_Float64(dotf_Array(leftf, rightf), dotf_List(left_list, right_list))
    zip_sum_ok = eq_Float64(
      zip_sumf_Array(left, right, (l, r) -> int_to_Float64(mul(l, r))),
      dotf_List(left_list, right_list)
    )
    ok = and(
      eq_List(eq_Int)(zipped, zipped_expected),
      and(
        eq_Int(folded, folded_expected),
        and(sum_ok, and(sumsq_ok, and(dot_ok, zip_sum_ok)))
      )
    )
    Assertion(ok, "zip helpers truncate to the visible prefix and Float64 reductions stay left to right")
  ))

tests = TestSuite("Array tests", [
  Assertion(eq_Int64(size_Array(a0), i64(0)), "empty size"),
  Assertion(to_List_Array(a0) matches [], "empty to list"),
  Assertion(to_List_Array(a5) matches [0, 1, 2, 3, 4], "range 5"),
  Assertion(to_List_Array(a_from) matches [10, 11, 12, 13], "range_from 10,4"),
  Assertion(eq_ai(a0, a0_copy), "eq_Array empty"),
  Assertion(eq_ai(a1, a1_copy), "eq_Array singleton equal"),
  Assertion(eq_ai(a1, a1_diff) matches False, "eq_Array singleton mismatch"),
  Assertion(eq_ai(a5, a5_copy), "eq_Array equal copy"),
  Assertion(eq_ai(a5, a5_first_diff) matches False, "eq_Array first element mismatch"),
  Assertion(eq_ai(a5, a5_last_diff) matches False, "eq_Array last element mismatch"),
  Assertion(get_Array(a5, i64(0)).eq_oi(Some(0)), "get first"),
  Assertion(get_Array(a5, i64(4)).eq_oi(Some(4)), "get last"),
  Assertion(get_Array(a5, i64(-1)).eq_oi(None), "get negative"),
  Assertion(get_Array(a5, i64(5)).eq_oi(None), "get out of range"),
  Assertion(get_or_Array(a5, i64(2), int64_to_Int) matches 2, "get_or in range"),
  Assertion(get_or_Array(a5, i64(10), int64_to_Int) matches 10, "get_or fallback forwards idx"),
  Assertion(foldl_Array(a5, 0, add) matches 10, "foldl add"),
  Assertion(
    foldl_with_index_Array(a5, 0, (acc, item, idx) -> add(acc, add(item, int64_to_Int(idx)))) matches 20,
    "foldl_with_index add"
  ),
  Assertion(foldr_Array(a5, 0, (x, acc) -> sub(x, acc)) matches 2, "foldr order"),
  Assertion(to_List_Array(map_Array(a5, i -> i.add(1))) matches [1, 2, 3, 4, 5], "map add 1"),
  Assertion(
    to_List_Array(map_with_index_Array(a5, (item, idx) -> add(item, int64_to_Int(idx)))) matches [0, 2, 4, 6, 8],
    "map_with_index add idx"
  ),
  Assertion(to_List_Array(filter_Array(a5, i -> i.mod_Int(2) matches 0)) matches [0, 2, 4], "filter evens"),
  Assertion(to_List_Array(filter_Array(a5, _ -> False)) matches [], "filter none"),
  Assertion(
    to_List_Array(flat_map_Array(a5, i -> from_List_Array([i, i.add(10)]))) matches [0, 10, 1, 11, 2, 12, 3, 13, 4, 14],
    "flat_map dup"
  ),
  Assertion(
    to_List_Array(flat_map_Array(a5, i ->
      if i.mod_Int(2) matches 0:
        from_List_Array([i])
      else:
        empty_Array
    )) matches [0, 2, 4],
    "flat_map selective"
  ),
  Assertion(to_List_Array(filter_Array(a5_tail, i -> i.mod_Int(2) matches 1)) matches [3], "filter slice"),
  Assertion(
    to_List_Array(flat_map_Array(a5_tail, i -> from_List_Array([i, i.add(20)]))) matches [2, 22, 3, 23, 4, 24],
    "flat_map slice"
  ),
  Assertion(to_List_Array(a_set) matches [0, 1, 99, 3, 4], "set_or_self in range"),
  Assertion(eq_ai(set_or_self_Array(a5, i64(9), 77), a5), "set_or_self out of range keeps self"),
  Assertion(set_in_range_ok(), "set_Array in range"),
  Assertion(set_Array(a5, i64(10), 8) matches None, "set_Array out of range"),
  Assertion(to_List_Array(concat_all_Array([a5, range_Array(3), empty_Array])) matches [0, 1, 2, 3, 4, 0, 1, 2], "concat_all"),
  Assertion(to_List_Array(slice_Array(a5, i64(1), i64(4))) matches [1, 2, 3], "slice mid"),
  Assertion(to_List_Array(slice_Array(a5, i64(-2), i64(2))) matches [0, 1], "slice clamps start"),
  Assertion(to_List_Array(slice_Array(a5, i64(3), i64(99))) matches [3, 4], "slice clamps end"),
  Assertion(to_List_Array(slice_Array(a5, i64(3), i64(3))) matches [], "slice empty"),
  Assertion(to_List_Array(slice_Array(a5, i64(4), i64(1))) matches [], "slice invalid order"),
  Assertion(to_List_Array(slice_Array(a5, i64(1), i64(-1))) matches [], "slice invalid end"),
  Assertion(get_or_Array(a5_tail, i64(0), int64_to_Int) matches 2, "slice index is relative"),
  Assertion(
    to_List_Array(zip_map_Array(a5, range_from_Array(10, i64(3)), (l, r) -> add(l, r))) matches [10, 12, 14],
    "zip_map truncates"
  ),
  Assertion(
    zip_foldl_Array(a5, range_from_Array(10, i64(3)), 0, (acc, l, r) -> add(acc, add(l, r))) matches 36,
    "zip_foldl truncates"
  ),
  Assertion(
    eq_Float64(
      zip_sumf_Array(a5, range_from_Array(10, i64(3)), (l, r) -> int_to_Float64(mul(l, r))),
      35.0
    ),
    "zip_sumf truncates"
  ),
  Assertion(eq_Float64(sumf_Array(map_Array(a5, int_to_Float64)), 10.0), "sumf"),
  Assertion(eq_Float64(sumsqf_Array(map_Array(a5, int_to_Float64)), 30.0), "sumsqf"),
  Assertion(
    eq_Float64(dotf_Array(map_Array(a5, int_to_Float64), map_Array(range_from_Array(10, i64(3)), int_to_Float64)), 35.0),
    "dotf truncates"
  ),
  Assertion(eq_Float64(sumf_Array(empty_Array), 0.0), "sumf empty"),
  Assertion(eq_Float64(dotf_Array(empty_Array, empty_Array), 0.0), "dotf empty"),
  Assertion(
    float64_bits_to_Int(sumf_Array(from_List_Array([-0.0]))) matches 0x8000_0000_0000_0000,
    "sumf preserves negative zero"
  ),
  Assertion(char_Array_to_String(from_List_Array([.'h', .'i'])) matches "hi", "char_Array_to_String ascii"),
  Assertion(char_Array_to_String(from_List_Array([.'👋', .'a'])) matches "👋a", "char_Array_to_String unicode"),
  Assertion(to_List_Array(string_to_Char_Array("hi👋")) matches [.'h', .'i', .'👋'], "string_to_Char_Array"),
  Assertion(to_List_Array(char_Array_to_Int_Array(from_List_Array([.'A', .'👋']))) matches [65, 128075], "char_Array_to_Int_Array"),
  Assertion(to_List_Array(string_to_Int_Array("A👋")) matches [65, 128075], "string_to_Int_Array"),
  Assertion(int_to_char_array_some(), "int_Array_to_Char_Array some"),
  Assertion(
    int_Array_to_Char_Array(from_List_Array([55296])) matches None,
    "int_Array_to_Char_Array none"
  ),
  Assertion(
    int_Array_to_String(from_List_Array([65, 128075])) matches Some("A👋"),
    "int_Array_to_String some"
  ),
  Assertion(
    int_Array_to_String(from_List_Array([55296])) matches None,
    "int_Array_to_String none"
  ),
  Assertion(to_List_Array(reverse_Array(a5)) matches [4, 3, 2, 1, 0], "reverse"),
  Assertion(to_List_Array(flatten_Array(from_List_Array([range_Array(2), range_from_Array(10, i64(2)), empty_Array]))) matches [0, 1, 10, 11], "flatten"),
  Assertion(to_List_Array(a_sorted) matches [(0, "z"), (1, "a"), (1, "b"), (1, "c")], "stable sort"),
  Assertion(get_map_Array(a5, i64(3), _ -> 100, x -> x.add(7)) matches 10, "get_map some"),
  Assertion(get_map_Array(a5, i64(30), _ -> 100, x -> x.add(7)) matches 100, "get_map none"),
  Assertion(index_in_range_Array(a5, i64(0)), "index in range 0"),
  Assertion(index_in_range_Array(a5, i64(4)), "index in range 4"),
  Assertion(index_in_range_Array(a5, i64(5)) matches False, "index not in range"),
  run_Prop(foldr_reverse_law, 80, 4242),
  run_Prop(tabulate_law, 80, 5151),
  run_Prop(indexed_slice_law, 80, 6161),
  run_Prop(zip_and_float_law, 80, 7171),
])
