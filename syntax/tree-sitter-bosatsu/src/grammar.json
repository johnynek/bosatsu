{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "bosatsu",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "package_declaration"
          },
          {
            "type": "SYMBOL",
            "name": "statement"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "_indent"
          },
          {
            "type": "SYMBOL",
            "name": "_dedent"
          }
        ]
      }
    },
    "package_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "package"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "package_name"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "package_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "package_segment"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "/"
              },
              {
                "type": "SYMBOL",
                "name": "package_segment"
              }
            ]
          }
        }
      ]
    },
    "package_segment": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_]*"
    },
    "statement": {
      "type": "SYMBOL",
      "name": "simple_statement"
    },
    "block_statement": {
      "type": "PREC_RIGHT",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "header",
            "content": {
              "type": "SYMBOL",
              "name": "header_line"
            }
          },
          {
            "type": "STRING",
            "value": ":"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "_indent"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "statement"
                },
                {
                  "type": "SYMBOL",
                  "name": "_newline"
                }
              ]
            }
          },
          {
            "type": "SYMBOL",
            "name": "_dedent"
          }
        ]
      }
    },
    "header_line": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "header_item"
      }
    },
    "header_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "type_identifier"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "unknown"
        }
      ]
    },
    "simple_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "line_items"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "line_items": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "line_item"
      }
    },
    "line_item": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "type_identifier"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        },
        {
          "type": "SYMBOL",
          "name": "unknown"
        }
      ]
    },
    "atom": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "list"
        },
        {
          "type": "SYMBOL",
          "name": "tuple"
        },
        {
          "type": "SYMBOL",
          "name": "record"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "character"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "backticked_identifier"
        }
      ]
    },
    "tuple": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "("
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "line_item"
              },
              {
                "type": "SYMBOL",
                "name": "_newline"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": ")"
        }
      ]
    },
    "list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "line_item"
              },
              {
                "type": "SYMBOL",
                "name": "_newline"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "line_item"
              },
              {
                "type": "SYMBOL",
                "name": "_newline"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "def"
        },
        {
          "type": "STRING",
          "value": "enum"
        },
        {
          "type": "STRING",
          "value": "struct"
        },
        {
          "type": "STRING",
          "value": "external"
        },
        {
          "type": "STRING",
          "value": "if"
        },
        {
          "type": "STRING",
          "value": "elif"
        },
        {
          "type": "STRING",
          "value": "else"
        },
        {
          "type": "STRING",
          "value": "match"
        },
        {
          "type": "STRING",
          "value": "case"
        },
        {
          "type": "STRING",
          "value": "recur"
        },
        {
          "type": "STRING",
          "value": "loop"
        },
        {
          "type": "STRING",
          "value": "from"
        },
        {
          "type": "STRING",
          "value": "import"
        },
        {
          "type": "STRING",
          "value": "export"
        },
        {
          "type": "STRING",
          "value": "operator"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-z_][A-Za-z0-9_]*"
    },
    "type_identifier": {
      "type": "PATTERN",
      "value": "[A-Z][A-Za-z0-9_]*"
    },
    "backticked_identifier": {
      "type": "PATTERN",
      "value": "`[^`\\n]+`"
    },
    "number": {
      "type": "PATTERN",
      "value": "-?(0[xX][0-9A-Fa-f_]+|0[oO][0-7_]+|0[bB][0-1_]+|[0-9][0-9_]*(\\.[0-9_]+)?)"
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "\"([^\"\\\\\\n]|\\\\.|\\$\\{([^{}]|\\{[^{}]*\\})*\\})*\""
          },
          {
            "type": "PATTERN",
            "value": "'([^'\\\\\\n]|\\\\.)*'"
          }
        ]
      }
    },
    "character": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "'"
                  },
                  {
                    "type": "REPEAT",
                    "content": {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "PATTERN",
                          "value": "[^'\\\\\\n]+"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\."
                        }
                      ]
                    }
                  },
                  {
                    "type": "STRING",
                    "value": "'"
                  }
                ]
              },
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": "\""
                  },
                  {
                    "type": "REPEAT",
                    "content": {
                      "type": "CHOICE",
                      "members": [
                        {
                          "type": "PATTERN",
                          "value": "[^\"\\\\\\n]+"
                        },
                        {
                          "type": "PATTERN",
                          "value": "\\\\."
                        }
                      ]
                    }
                  },
                  {
                    "type": "STRING",
                    "value": "\""
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    "operator": {
      "type": "PATTERN",
      "value": "[!$%&*+\\-./<=>?@\\\\^|~]+"
    },
    "unknown": {
      "type": "PATTERN",
      "value": "[^\\s:\\[\\]\\(\\)\\{\\}]+"
    },
    "punctuation": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "STRING",
          "value": "."
        },
        {
          "type": "STRING",
          "value": ";"
        },
        {
          "type": "STRING",
          "value": "="
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\r\\f]+"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [
    [
      "header_item",
      "line_item"
    ]
  ],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_newline"
    },
    {
      "type": "SYMBOL",
      "name": "_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_dedent"
    }
  ],
  "inline": [],
  "supertypes": [
    "statement",
    "atom"
  ]
}
