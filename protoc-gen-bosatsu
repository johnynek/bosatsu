#!/bin/bash

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)
jar_path="$(
  ls -1t "$SCRIPT_DIR"/cli/target/scala-*/bosatsu-cli-assembly-*.jar 2>/dev/null | head -n 1 || true
)"

if [ -z "$jar_path" ]; then
  echo "protoc-gen-bosatsu: no assembly jar found; run sbt cli/assembly first" >&2
  exit 1
fi

java -cp "$jar_path" dev.bosatsu.protobuf.ProtocPluginMain "$@"
